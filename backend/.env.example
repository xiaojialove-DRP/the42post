# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/42post_db

# Authentication
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_recommended
JWT_EXPIRY=24h

# LLM (Google Gemini — used for probe + five-layer generation)
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Optional: override default model (defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Signing & Security
SIGNING_SECRET=your_hmac_signing_secret_minimum_32_characters

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8000

# Email — Resend (HTTP API; Railway blocks SMTP)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# Optional: "From" address. Defaults to onboarding@resend.dev (Resend's test
# sender, no domain verification needed). For production, verify your own
# domain in Resend and set this to e.g. noreply@yourdomain.com
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=THE 42 POST
