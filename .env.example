# ═══════════════════════════════════════════════════════
# THE 42 POST — Environment Configuration
# Copy this file to .env and fill in actual values
# ═══════════════════════════════════════════════════════

# DATABASE
# For PostgreSQL (Railway default):
DATABASE_URL=postgresql://user:password@host:5432/42post_db
# For SQLite (local development):
# DATABASE_URL=sqlite:./data/42post.db

# AUTHENTICATION
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_recommended_change_in_production
JWT_EXPIRY=24h

# CLAUDE API
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# SIGNING & SECURITY
SIGNING_SECRET=your_hmac_signing_secret_minimum_32_characters_change_in_production

# SERVER
PORT=3000
NODE_ENV=development
# In production (Railway), set to your Railway domain:
# FRONTEND_URL=https://yourapp-production.up.railway.app
FRONTEND_URL=http://localhost:8000

# EMAIL (optional, for verification and notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@42post.com
SMTP_PASSWORD=your_app_password

# LOGGING
LOG_LEVEL=info
# Deployment fix attempt
