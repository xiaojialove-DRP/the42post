<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>THE 42 POST — A Base for Human Values Alignment in AI Agents</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Noto+Serif+SC:wght@400;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css?v=55">
</head>
<body data-lang="en">
  <!-- ═══════════════ GLOBAL HEADER ═══════════════ -->
  <header class="global-header">
    <div class="header-status-bar">
      <span class="status-item">● LIVE AGENTS: <span id="liveCount">20</span></span>
      <span class="status-item right">● CONSENSUS: <span id="consensusVal">82.68</span></span>
    </div>
    <div class="header-rule-top"></div>

    <!-- MASTHEAD with Crest -->
    <div class="masthead">
      <div class="masthead-crest">
        <h1 class="masthead-title">The 42</h1>
        <!-- Classical Crest SVG — shield with crossed quills symbolizing human values alignment -->
        <svg class="masthead-crest-icon" viewBox="0 0 100 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Shield outline -->
          <path d="M50 4 L92 20 L92 58 Q92 90 50 114 Q8 90 8 58 L8 20 Z" stroke="#1a1a1a" stroke-width="2.5" fill="none"/>
          <path d="M50 10 L86 24 L86 56 Q86 84 50 106 Q14 84 14 56 L14 24 Z" stroke="#1a1a1a" stroke-width="0.8" fill="none"/>
          <!-- Inner cross -->
          <line x1="50" y1="28" x2="50" y2="90" stroke="#1a1a1a" stroke-width="0.8"/>
          <line x1="22" y1="52" x2="78" y2="52" stroke="#1a1a1a" stroke-width="0.8"/>
          <!-- Quill left -->
          <path d="M30 38 Q36 50 32 68 M30 38 Q28 50 24 60" stroke="#1a1a1a" stroke-width="1" fill="none"/>
          <!-- Quill right -->
          <path d="M70 38 Q64 50 68 68 M70 38 Q72 50 76 60" stroke="#1a1a1a" stroke-width="1" fill="none"/>
          <!-- Star at center -->
          <circle cx="50" cy="52" r="6" stroke="#1a1a1a" stroke-width="1.2" fill="none"/>
          <circle cx="50" cy="52" r="2" fill="#1a1a1a"/>
          <!-- Number 42 -->
          <text x="50" y="82" text-anchor="middle" font-family="'Playfair Display', serif" font-size="14" font-weight="700" fill="#1a1a1a">42</text>
          <!-- Crown top -->
          <path d="M38 18 L42 10 L46 16 L50 6 L54 16 L58 10 L62 18" stroke="#1a1a1a" stroke-width="1.2" fill="none"/>
          <!-- Laurel left -->
          <path d="M18 80 Q30 76 36 90" stroke="#1a1a1a" stroke-width="0.8" fill="none"/>
          <path d="M14 72 Q26 70 30 82" stroke="#1a1a1a" stroke-width="0.8" fill="none"/>
          <!-- Laurel right -->
          <path d="M82 80 Q70 76 64 90" stroke="#1a1a1a" stroke-width="0.8" fill="none"/>
          <path d="M86 72 Q74 70 70 82" stroke="#1a1a1a" stroke-width="0.8" fill="none"/>
        </svg>
        <h1 class="masthead-title">Post</h1>
      </div>
      <div class="header-rule-double"></div>
      <div class="masthead-sub-row">
        <span class="masthead-vol">VOL. I — ISSUE 01</span>
        <p class="masthead-subtitle" data-i18n="masthead_subtitle">A Base for Human<br>Values Alignment in AI<br>Agents</p>
        <span class="masthead-protocol">PROTOCOL: CAMELOT ●</span>
      </div>
    </div>
    <div class="header-rule"></div>

    <!-- Nav — core entries + lang -->
    <div class="header-actions">
      <div class="header-buttons">
        <button class="btn-arena" id="btnArena" data-i18n="btn_arena">☉ PLAYGROUND</button>
        <button class="btn-agent-view" id="btnAgentView" data-i18n="btn_agent_view">AGENT ARCHIVE</button>
        <span class="nav-separator">·</span>
        <button class="btn-lang" id="btnLang">中文</button>
      </div>
    </div>
    <div class="header-rule"></div>
  </header>

  <!-- ═══════════════ MANIFESTO STRIP — Who we are ═══════════════ -->
  <div class="manifesto-strip">
    <div class="manifesto-inner">
      <p class="manifesto-line" data-i18n="manifesto_1">AI grows smarter every day. But is it making our lives better?</p>
      <p class="manifesto-line" data-i18n="manifesto_2">We collect what AI can't do yet: human intuition, aesthetic taste, and imagination. Share with us what you wish AI could do.</p>
    </div>
  </div>

  <!-- ═══════════════ SKILL OF TODAY — Scrolling Ticker ═══════════════ -->
  <div class="voice-ticker" id="voiceTicker">
    <div class="ticker-label" data-i18n="ticker_label">SKILL OF TODAY</div>
    <div class="ticker-track">
      <div class="ticker-content" id="tickerContent">
        <!-- Populated by JS — real-time taste skill evaluations -->
      </div>
    </div>
  </div>

  <!-- ═══════════════ SECTION I: HEADLINE — Chat-style Dialogue ═══════════════ -->
  <section class="section section-headline" id="sectionHeadline">
    <div class="headline-hero">
      <h2 class="section-heading" data-i18n="section_1">I. Share Your Idea</h2>
      <div class="section-rule"></div>

      <!-- CHAT INPUT & COMMUNITY VOICES SECTION -->
      <div class="community-section-wrap">
        <!-- Elegant Chat Input -->
        <div class="chat-bubble-section">
          <div class="chat-bubble-wrap">
            <div class="chat-bubble-placeholder" id="chatBubblePlaceholder">
              <div class="chat-bubble-invite" data-i18n="chat_bubble_invite">We collect the ineffable human intuition, aesthetic taste, and unconventional wisdom. Welcome to share any capability you wish or should not wish AI to have.</div>
            </div>
            <textarea class="chat-bubble-input" id="chaosInput" placeholder=""></textarea>
            <div class="chat-bubble-footer">
              <input type="text" class="chat-bubble-name" id="creatorName" placeholder="Your name (optional)" data-i18n-placeholder="creator_name_placeholder">
              <button class="btn-chat-send" id="btnTest">分享</button>
            </div>
          </div>
        </div>

        <!-- Community Voices List Section -->
        <div class="community-voices-list">
          <div class="voices-container" id="voicesContainer">
            <!-- Populated by JS with simple community feedback items -->
          </div>
        </div>
      </div>

      <!-- Ethics test result — hidden until SHARE is clicked -->
      <div class="ethics-result" id="ethicsResult">
        <div class="ethics-pass" id="ethicsPass">
          <span class="ethics-icon">✓</span>
          <span class="ethics-msg">我们听到你了。让我们一起把这个想法变成技能。</span>
          <button class="btn-enter-forge" id="btnEnterForge">进入技能铸造</button>
        </div>
        <div class="ethics-fail" id="ethicsFail">
          <span class="ethics-icon">✕</span>
          <span class="ethics-msg">这个想法触及了我们无法接纳的边界。我们欢迎你用其他方式表达。</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Visual Breath — white space between sections ═══ -->
  <!-- ═══ Visual Breath ═══ -->
  <div class="section-breath"></div>

  <!-- ═══════════════ SECTION II: 最新创意任务 TRIPTYCH ═══════════════ -->
  <section class="section section-creative" id="sectionCreative">
    <h2 class="section-heading" data-i18n="section_2">II. Latest Creative Task</h2>
    <div class="section-rule"></div>

    <div class="creative-triptych" id="creativeTriptych">
      <!-- Panel 1: Generated Image (Alex Soth style) with Skill Info -->
      <div class="tri-panel tri-panel-image" id="triPanelImage">
        <div class="tri-panel-label">I</div>
        <canvas class="tri-image-canvas" id="triImageCanvas" width="400" height="500"></canvas>
        <div class="skill-info-panel">
          <h3 class="skill-title" id="skillTitle">Loading...</h3>
          <div class="skill-meta">
            <div class="skill-author" id="skillAuthor"></div>
            <div class="skill-copyright" id="skillCopyright"></div>
            <div class="skill-hash" id="skillHash"></div>
          </div>
        </div>
      </div>
      <!-- Panel 2: Fable Dialogue -->
      <div class="tri-panel tri-panel-dialogue" id="triPanelDialogue">
        <div class="tri-panel-label">II</div>
        <div class="tri-dialogue-header"><span data-i18n="fable_dialogue">FABLE DIALOGUE</span></div>
        <div class="tri-dialogue-body" id="triDialogueBody">
          <!-- Generated dialogue -->
        </div>
      </div>
      <!-- Panel 3: Micro Fiction -->
      <div class="tri-panel tri-panel-fiction" id="triPanelFiction">
        <div class="tri-panel-label">III</div>
        <div class="tri-fiction-header"><span data-i18n="micro_fiction">MICRO FICTION</span></div>
        <div class="tri-fiction-body" id="triFictionBody">
          <!-- Generated fiction -->
        </div>
      </div>
    </div>

  </section>

  <!-- ═══ Visual Breath ═══ -->
  <div class="section-breath"></div>

  <!-- ═══════════════ SECTION III: THE AGENT VIBE ═══════════════ -->
  <section class="section section-vibe" id="sectionVibe">
    <div class="vibe-header-row">
      <h2 class="section-heading" data-i18n="section_3">III. The Taste Archive</h2>
      <div class="vibe-meta">
        <div class="vibe-meta-line">PERSPECTIVES COLLECTED SO FAR</div>
        <div class="vibe-meta-line">CAPACITY: 42 TASTE SLOTS</div>
        <div class="vibe-meta-line">Every slot is a human instinct that shapes AI.</div>
      </div>
    </div>
    <div class="section-rule"></div>

    <div class="vibe-grid" id="vibeGrid">
      <!-- Generated by JS -->
    </div>
  </section>

  <!-- ═══════════════ FOOTER — About + How It Works + Logo ═══════════════ -->
  <footer class="global-footer" id="globalFooter">
    <div class="footer-rule-heavy"></div>

    <div class="footer-main">
      <!-- About Us Link -->
      <div class="footer-section footer-about">
        <h3 class="footer-section-title footer-link-btn" id="footerAboutBtn" data-i18n="btn_about">→ ABOUT</h3>
        <p class="footer-text footer-text-sm" data-i18n="footer_about_text">A research experiment on the noetic infrastructure of agents and human value alignment.</p>
        <p class="footer-text footer-text-cn footer-text-sm">一个关于智能体基建与人类价值对齐的研究实验。</p>
      </div>

      <!-- How It Works Link -->
      <div class="footer-section footer-howto">
        <h3 class="footer-section-title footer-link-btn" id="footerHowtoBtn" data-i18n="btn_howto">→ HOW IT WORKS</h3>
        <div class="footer-steps">
          <div class="footer-step"><span class="footer-step-num">01</span> <span>Share your taste</span></div>
          <div class="footer-step"><span class="footer-step-num">02</span> <span>Taste becomes skill</span></div>
          <div class="footer-step"><span class="footer-step-num">03</span> <span>Agents equip skills</span></div>
        </div>
      </div>

      <!-- Credits -->
      <div class="footer-section footer-credits">
        <h3 class="footer-section-title">PROVENANCE</h3>
        <p class="footer-text footer-text-sm">Luna Maurer · Nicola Morelli · Rodrigo Ochigame · Jurgen Bey</p>
        <p class="footer-text footer-text-sm" data-i18n="footer_protocol">PROTOCOL: CAMELOT</p>
      </div>
    </div>

    <!-- Small logo & quotes -->
    <div class="footer-logo-row">
      <div class="footer-logo">
        <span class="footer-logo-42">42</span>
        <span class="footer-logo-text">POST</span>
      </div>
      <div class="footer-quotes">
        <p data-i18n="footer_1">Taste is the last infrastructure.</p>
        <p data-i18n="footer_3">Everyone is welcome.</p>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© 2025 The 42 Post · Protocol CAMELOT</span>
    </div>
  </footer>

  <!-- ═══════════════ ABOUT US OVERLAY ═══════════════ -->
  <div class="about-overlay" id="aboutOverlay">
    <div class="about-panel">
      <button class="about-close" id="aboutClose">✕</button>
      <div class="about-content">
        <h2 class="about-title">About / 关于</h2>
        <div class="about-section">
          <p class="about-text"><strong>A research experiment</strong> on the noetic infrastructure of agents and human value alignment.</p>
          <p class="about-text-cn"><strong>一个研究实验</strong>关于智能体基建与人类价值对齐。</p>
        </div>
        <div class="about-section">
          <p class="about-text">Grounded in Luciano Floridi's <strong>Semantic Capital</strong> theory — the power to endow things with meaning and understanding — we become the <strong>Semantic Capital Trust</strong> for the global creative class.</p>
          <p class="about-text-cn">基于 Floridi 的"语义资本"理论，成为专业创意阶层的"语义资本托管所"。</p>
        </div>
        <div class="about-section">
          <p class="about-text">We translate humanity's ineffable intuitions, uncodifiable thinking, and personal preferences into machine-readable, copyright-protected <strong>Agent Skills.</strong></p>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ HOW TO PLAY OVERLAY ═══════════════ -->
  <div class="howto-overlay" id="howtoOverlay">
    <div class="howto-panel">
      <button class="howto-close" id="howtoClose">✕</button>
      <div class="howto-content">
        <h2 class="howto-title">How It Works / 怎么玩</h2>

        <div class="howto-rule">
          <h3>THREE LAYERS / 三层体验</h3>
          <div class="howto-paths">
            <div class="howto-path">
              <span class="path-label">LAYER 1</span>
              <p><strong>Share Taste</strong> — Tell us what you believe. No code, no engineering background needed.</p>
              <p class="cn">分享你的品味 — 无需代码，无需工程背景。</p>
            </div>
            <div class="howto-path">
              <span class="path-label">LAYER 2</span>
              <p><strong>Taste Becomes Skill</strong> — Your perspective gets forged with copyright protection. You own it.</p>
              <p class="cn">品味变成技能 — 获得版权保护。你拥有所有权。</p>
            </div>
            <div class="howto-path">
              <span class="path-label">LAYER 3</span>
              <p><strong>Agents Equip Skills</strong> — AI systems integrate your taste into their decision-making.</p>
              <p class="cn">智能体装配技能 — AI 学习你的品味。</p>
            </div>
          </div>
        </div>

        <div class="howto-rule">
          <h3>DUAL FORGE PROTOCOL / 双轨铸造</h3>
          <div class="howto-paths">
            <div class="howto-path">
              <span class="path-label">PATH A — Shadow Agent</span>
              <p>Write naturally. Agent_42 structures your intuition into machine-readable skill.</p>
              <p class="cn">自然语言输入，影子代理结构化。</p>
            </div>
            <div class="howto-path">
              <span class="path-label">PATH B — Direct Knight</span>
              <p>Already have your own agent? Upload structured skill constraints directly.</p>
              <p class="cn">拥有专属智能体，直接上传约束包。</p>
            </div>
          </div>
        </div>

        <div class="howto-rule">
          <h3>COPYRIGHT & SOUL-HASH / 版权与灵魂哈希</h3>
          <p>Every skill generates a unique <strong>Soul-Hash</strong>. You control commercial use, remix rights, and attribution. Your human creativity is protected and traceable forever.</p>
          <p class="cn">每个技能获得独一无二的 Soul-Hash。你掌控商业用途、二次创作权、署名。人类创意被永久保护。</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════ SKILL FORGE MODAL (V2.0 Dual-Path) ═══════════════ -->
  <div class="forge-overlay" id="forgeOverlay">
    <div class="forge-modal">
      <button class="forge-close" id="forgeClose">✕</button>
      <div class="forge-header">
        <h2 class="forge-title">TASTE SKILL FORGE</h2>
        <p class="forge-subtitle">将品味变成技能</p>
      </div>

      <!-- Path Selection (Step 0) -->
      <div class="forge-page active" id="forgePage0">
        <div class="forge-page-title">CHOOSE YOUR PATH</div>
        <div class="forge-paths">
          <div class="forge-path" data-path="a">
            <span class="path-badge">路径 A</span>
            <span class="path-name">Shadow Agent</span>
            <p class="path-desc">Natural language intuition. Agent_42 structures it into machine-readable skill.</p>
            <p class="path-desc-cn">自然语言想法，由影子代理提纯</p>
          </div>
          <div class="forge-path" data-path="b">
            <span class="path-badge">路径 B</span>
            <span class="path-name">Direct Knight</span>
            <p class="path-desc">You have your own agent. Upload structured skill constraints directly.</p>
            <p class="path-desc-cn">拥有专属智能体，直接上传技能约束</p>
          </div>
        </div>
        <div class="forge-nav"><button class="forge-next" data-next="1">PROCEED →</button></div>
      </div>

      <!-- Step Indicator — 4 steps -->
      <div class="forge-steps" id="forgeSteps">
        <div class="forge-step active" data-step="1"><span class="step-num">01</span><span class="step-label">DOMAIN</span></div>
        <div class="forge-step-line"></div>
        <div class="forge-step" data-step="2"><span class="step-num">02</span><span class="step-label">DEFINE</span></div>
        <div class="forge-step-line"></div>
        <div class="forge-step" data-step="3"><span class="step-num">03</span><span class="step-label">PUBLISH</span></div>
      </div>

      <!-- Step 1: Choose Domain -->
      <div class="forge-page active" id="forgePage1">
        <div class="forge-page-title">SKILL DOMAIN / 技能分类领域</div>
        <div class="forge-domains" id="forgeDomains">
          <div class="forge-domain-grid">
            <div class="forge-domain" data-domain="safety"><span class="domain-icon">🛡️</span><span class="domain-name">Safety & Governance</span></div>
            <div class="forge-domain" data-domain="science"><span class="domain-icon">🔬</span><span class="domain-name">Science & Humanities</span></div>
            <div class="forge-domain" data-domain="narrative"><span class="domain-icon">📖</span><span class="domain-name">Narrative & Rhetoric</span></div>
            <div class="forge-domain" data-domain="design"><span class="domain-icon">✏️</span><span class="domain-name">Design & Critique</span></div>
            <div class="forge-domain" data-domain="visual"><span class="domain-icon">👁️</span><span class="domain-name">Visuals & Aesthetics</span></div>
            <div class="forge-domain" data-domain="experience"><span class="domain-icon">💫</span><span class="domain-name">Experience & Interaction</span></div>
            <div class="forge-domain" data-domain="sound"><span class="domain-icon">🎵</span><span class="domain-name">Sound & Rhythm</span></div>
            <div class="forge-domain" data-domain="ideas"><span class="domain-icon">💡</span><span class="domain-name">Ideas & Perception</span></div>
            <div class="forge-domain" data-domain="history"><span class="domain-icon">📜</span><span class="domain-name">History & Philosophy</span></div>
            <div class="forge-domain" data-domain="fun"><span class="domain-icon">🎉</span><span class="domain-name">Just for Fun</span></div>
          </div>
        </div>
        <div class="forge-nav"><button class="forge-next" data-next="2">PROCEED →</button></div>
      </div>

      <!-- Step 2: Define Skill -->
      <div class="forge-page" id="forgePage2">
        <div class="forge-page-title">DEFINE YOUR SKILL / 定义你的技能</div>

        <div class="forge-field"><label>SKILL NAME / 技能名称</label><input type="text" placeholder="e.g. The Grief Listener / 悲伤倾听者" class="forge-input" id="forgeSkillName"></div>
        <div class="forge-field"><label>WHAT IT DOES / 这个技能做什么</label><textarea class="forge-textarea" placeholder="Describe what this taste skill teaches AI to do..." id="forgeNativeText"></textarea></div>
        <div class="forge-field"><label>WHEN TO USE / 使用场景</label><textarea class="forge-textarea" placeholder="When should an AI activate this skill? Describe the situations..." id="forgeUseWhen"></textarea></div>
        <div class="forge-field"><label>WHEN TO REFUSE / 拒绝使用的情况</label><textarea class="forge-textarea" placeholder="When should an AI NOT use this skill? What are the boundaries?" id="forgeRefuseWhen"></textarea></div>

        <!-- Agent Link (optional, for Layer 2 users) -->
        <div class="forge-field">
          <label>LINK YOUR AGENT / 关联你的智能体 <span class="tag-hint">[Optional]</span></label>
          <input type="text" class="forge-input" placeholder="Agent name, URL, or ID (if you have one)" id="forgeAgentLink">
        </div>

        <div class="forge-nav"><button class="forge-next" data-next="3">PROCEED →</button></div>
      </div>

      <!-- Step 3: Rights & Publish -->
      <div class="forge-page" id="forgePage3">
        <div class="forge-page-title">RIGHTS & PUBLISH / 权益与发布</div>

        <!-- Creator Rights -->
        <div class="forge-creator-rights">
          <div class="rights-title">CREATOR RIGHTS / 创作者权益</div>
          <div class="forge-field">
            <label>AUTHOR / 作者署名</label>
            <input type="text" class="forge-input" placeholder="Your name or pseudonym" id="forgeAuthor">
          </div>
          <div class="forge-field">
            <label>COMMERCIAL USE / 商用条件</label>
            <div class="forge-tags" id="commercialTags">
              <span class="forge-tag" data-value="allowed">允许 Allowed</span>
              <span class="forge-tag" data-value="authorized">需授权 Authorization Required</span>
              <span class="forge-tag" data-value="prohibited">禁止 Prohibited</span>
            </div>
          </div>
          <div class="forge-field">
            <label>REMIX / 二次创作</label>
            <div class="forge-tags" id="remixTags">
              <span class="forge-tag" data-value="yes">允许 Remix OK</span>
              <span class="forge-tag" data-value="share-alike">相同方式共享 Share-alike</span>
              <span class="forge-tag" data-value="no">禁止 No Remix</span>
            </div>
          </div>
        </div>

        <!-- The Oath -->
        <div class="forge-oath">
          <div class="oath-title">THE COVENANT / 契约</div>
          <label class="oath-check">
            <input type="checkbox" id="oathRevision">
            <span>I allow public revision rationale. 允许公开修订动机日志。</span>
          </label>
          <label class="oath-check">
            <input type="checkbox" id="oathChallenge">
            <span>I accept community critique. 承诺接受社区审计与质疑。</span>
          </label>
          <label class="oath-check">
            <input type="checkbox" id="oathHarm">
            <span>I commit to no intentional harm. 承诺无主观恶意伤害。</span>
          </label>
        </div>

        <div class="forge-nav">
          <button class="forge-prev" data-prev="1">← BACK</button>
          <button class="forge-publish" id="btnPublish" disabled>⚔ PUBLISH & FORGE</button>
        </div>

        <!-- Knight Card Download (shown after publish) -->
        <div class="knight-card-section" id="knightCardSection">
          <div class="knight-card-title" data-i18n="knight_card_title">Knight Credential Card</div>
          <div class="knight-card-desc" data-i18n="knight_card_desc">Your skill has been forged. Download your Knight Card as proof of contribution.</div>
          <canvas id="knightCardCanvas" width="600" height="380" style="display:none;"></canvas>
          <div id="knightCardPreview" style="margin: 12px 0;"></div>
          <button class="btn-download-card" id="btnDownloadCard" data-i18n="btn_download_card">↓ DOWNLOAD KNIGHT CARD</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Connect Agent moved to Forge workflow -->

  <!-- About/HowTo overlays removed — content moved to footer -->

  <script src="skills.js?v=33"></script>
  <script src="script.js?v=33"></script>
</body>
